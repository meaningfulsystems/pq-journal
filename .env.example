# PQ Journal — Environment Variables
# Copy this to .env and set SECRET_KEY before running in production.

# REQUIRED: Set a strong random secret key for session signing.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# Optional overrides (also configurable in settings.yaml)
# JOURNAL_DIR=/home/user/MeaningfulJournal
# AUTO_LOCK_MINUTES=15
# STT_MODEL=large-v3-turbo
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2:3b
# ENABLE_WEBCAM=false
