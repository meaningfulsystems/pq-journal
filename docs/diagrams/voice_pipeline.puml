@startuml voice_pipeline
skinparam backgroundColor White
skinparam defaultBackgroundColor White
skinparam defaultFontColor #222222
skinparam defaultFontSize 11
skinparam ArrowColor #444444
skinparam SequenceBoxBorderColor #888888
skinparam SequenceBoxBackgroundColor #f5f5f5
skinparam SequenceParticipantBorderColor #555555
skinparam SequenceParticipantBackgroundColor #e8f0fe
skinparam SequenceLifeLineBorderColor #aaaaaa
skinparam NoteBackgroundColor #fffde7
skinparam NoteBorderColor #ccaa00
skinparam SequenceGroupBorderColor #999999
skinparam SequenceGroupBackgroundColor #f7f7f7

title PQ Journal — Voice Recording Pipeline (R061–R069)

participant "AudioWorklet\n(browser)" as aw
participant "WebSocket\n/ws/record" as ws
participant "voice.py\nserver" as voice
participant "tone.py\nToneEstimator" as tone
participant "stt.py\nWhisper/Vosk" as stt
participant "recorder.js\nUI" as ui

== Connection (R064, R069) ==

ui -> ws : Connect WebSocket
note right : Session cookie required (R069)\n4401 close if no valid session
ws -> voice : Accept connection
voice -> ui : {"type": "stt_engine",\n "engine": "whisper"}

== Live Recording (R061, R065) ==

loop Every 62.5ms (1000 samples)
  aw -> ws : Binary: 2000 bytes Int16 PCM
  ws -> voice : frame bytes

  voice -> voice : Compute RMS amplitude\nUpdate silence_frames counter

  opt Every 8 frames (~500ms)
    voice -> tone : estimate_vad(pcm_frame)
    tone --> voice : (V, A, D)
    voice -> ui : {"type": "vad",\n "V": 0.3, "A": 0.5, "D": 0.2,\n "label": "calm"} (R065)
  end

  opt silence_frames >= 16 AND buffer >= 32000 bytes (R062)
    voice -> ui : {"type": "transcribing"}
    voice -> stt : transcribe_pcm(buffer, 16000)
    note right : Runs in thread pool\n(non-blocking)
    stt --> voice : transcript text
    voice -> ui : {"type": "final",\n "text": "..."}
    voice -> voice : Clear buffer\nReset silence counter
  end
end

== Stop Recording (R063) ==

ui -> ws : {"type": "stop"}
voice -> voice : Flush remaining buffer if >= 32000 bytes
voice -> stt : transcribe_pcm(remaining)
stt --> voice : final text
voice -> ui : {"type": "final", "text": "..."}
voice -> ui : {"type": "vad_summary",\n "V": avg_V, "A": avg_A, "D": avg_D}
voice -> ui : {"type": "done"}

note over ui
  recorder.js accumulates transcripts
  in _transcriptBuffer for emotion window
end note

@enduml
