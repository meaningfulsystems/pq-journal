# PQ Journal — Settings
# Copy this file to settings.yaml and customize.
# Environment variables override YAML values.

# Journal storage directory (entries and SQLite DB stored here)
journal_dir: ~/MeaningfulJournal

# Auto-lock after N minutes of inactivity (0 = never)
auto_lock_minutes: 15

# Speech-to-text model (faster-whisper model name)
# Options: tiny, base, small, medium, large-v2, large-v3, large-v3-turbo
# Larger = more accurate, slower, more RAM
stt_model: large-v3-turbo

# Vosk model directory (fallback if faster-whisper not installed)
# vosk_model_dir: ~/.pq-journal/models/vosk-model-en-us-0.22

# Ollama settings (for emotion synthesis)
ollama_url: http://localhost:11434
ollama_model: llama3.2:3b

# Webcam emotion detection (requires: pip install feat)
# Set to true to enable facial Action Unit analysis
enable_webcam: false

# Server binding (do not change unless you know what you're doing)
host: 127.0.0.1
port: 8000
